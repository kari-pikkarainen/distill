# ── Build output ─────────────────────────────────────────────────────────────
/distill
/distill.exe

# GoReleaser snapshot/release artifacts
/dist/

# Temporary build workspace directories created by distill itself
/distill-dnf-*
/distill-apt-*

# ── Go ────────────────────────────────────────────────────────────────────────
# Test binary outputs
*.test
*.out

# ── Nix ───────────────────────────────────────────────────────────────────────
# nix build symlink
result
result-*

# ── devbox ───────────────────────────────────────────────────────────────────
.devbox/

# ── Wave 0 / local test bench outputs ────────────────────────────────────────
# Regenerated on every `devbox run mvp-local` run — not committable.
/evidence/
/test/bench/report/
/site/local/

# ── Claude Code ──────────────────────────────────────────────────────────────
# Track .claude/ (AGENTS.md, commands, etc.) but exclude machine-local settings
.claude/settings.local.json

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# .vscode/ is intentionally tracked for shared settings and recommended extensions
