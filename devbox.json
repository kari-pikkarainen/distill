{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "packages": [
    "go@latest",
    "golangci-lint@latest",
    "buildah@latest",
    "podman@latest",
    "skopeo@latest",
    "container-structure-test@latest",
    "cosign@latest",
    "grype@latest",
    "syft@latest",
    "oras@latest",
    "slsa-verifier@latest",
    "jq@latest",
    "yq-go@latest",
    "gitversion@latest",
    "goreleaser@latest",
    "lefthook@latest"
  ],
  "env": {
    "GOPATH": "$HOME/go",
    "GOBIN": "$HOME/go/bin"
  },
  "shell": {
    "init_hook": [
      "go install golang.org/x/tools/cmd/goimports@latest",
      "lefthook install",
      "echo 'distill dev environment ready'",
      "echo ''",
      "echo '  go build -o distill .   — build the CLI'",
      "echo '  devbox run --list       — see available scripts'"
    ],
    "scripts": {
      "unit-test": [
        "# Run unit tests (no integration tag).",
        "go test ./..."
      ],
      "lint": [
        "# Run golangci-lint against all packages.",
        "golangci-lint run ./..."
      ],
      "build-cli": [
        "# Build the distill CLI binary.",
        "VERSION=$(git describe --tags --always --dirty 2>/dev/null || echo dev)",
        "go build -ldflags \"-s -w -X github.com/damnhandy/distill/cmd.Version=${VERSION}\" -o distill .",
        "echo \"Built ./distill (${VERSION})\""
      ],
      "install-cli": [
        "# Install the distill CLI to $GOBIN.",
        "VERSION=$(git describe --tags --always --dirty 2>/dev/null || echo dev)",
        "go install -ldflags \"-s -w -X github.com/damnhandy/distill/cmd.Version=${VERSION}\" .",
        "echo \"Installed distill to $GOBIN (${VERSION})\""
      ],
      "test": [
        "# Usage: devbox run test <image:tag> <test-config.yaml>",
        "# Runs container-structure-test against a built image.",
        "container-structure-test test \\",
        "  --image \"${1:?Usage: devbox run test <image:tag> <config.yaml>}\" \\",
        "  --config \"${2:?missing test config}\""
      ],
      "scan": [
        "# Usage: devbox run scan <image:tag>",
        "# Scans an image for CVEs and fails on any CRITICAL findings.",
        "grype \"${1:?Usage: devbox run scan <image:tag>}\" --fail-on critical"
      ],
      "sbom": [
        "# Usage: devbox run sbom <image:tag> [output-file]",
        "# Generates an SPDX SBOM for an image.",
        "IMAGE=${1:?Usage: devbox run sbom <image:tag> [output-file]}",
        "OUT=${2:-sbom.spdx.json}",
        "syft \"${IMAGE}\" -o spdx-json > \"${OUT}\"",
        "echo \"SBOM written to ${OUT}\""
      ],
      "sign": [
        "# Usage: devbox run sign <image@digest>",
        "# Signs an image using keyless Sigstore. Set COSIGN_KEY for key-based signing.",
        "IMAGE=${1:?Usage: devbox run sign <image@digest>}",
        "if [ -n \"${COSIGN_KEY:-}\" ]; then",
        "  cosign sign --key \"${COSIGN_KEY}\" \"${IMAGE}\"",
        "else",
        "  cosign sign \"${IMAGE}\"",
        "fi"
      ],
      "inspect": [
        "# Usage: devbox run inspect <image:tag>",
        "# Shows image config and layer summary.",
        "skopeo inspect --config \"docker://${1:?Usage: devbox run inspect <image:tag>}\" | jq .",
        "echo ''",
        "skopeo inspect \"docker://${1}\" | jq '{Digest, Layers: (.Layers | length), Created, Labels, Env}'"
      ],
      "verify-slsa": [
        "# Usage: devbox run verify-slsa <image:tag> <provenance-file>",
        "# Verifies SLSA provenance for a published artifact.",
        "slsa-verifier verify-image \\",
        "  \"${1:?Usage: devbox run verify-slsa <image:tag> <provenance>}\" \\",
        "  --provenance-path \"${2:?missing provenance file}\" \\",
        "  --source-uri \"github.com/damnhandy/distill\""
      ],
      "mvp-local": [
        "# Wave 0 — run the full local MVP pipeline end-to-end on the host.",
        "# See scripts/mvp-local.sh for the step-by-step breakdown.",
        "./scripts/mvp-local.sh"
      ],
      "mvp-local-down": [
        "# Wave 0 — tear down the local registry and its data volume.",
        "cd local/registry && docker compose --profile cache down -v || true",
        "cd local/registry && docker compose down -v"
      ],
      "devbench-build": [
        "# Wave 0.10 — build the pinned build/scan/sign environment image.",
        "# Image digest will be recorded in benchmark and evidence artifacts.",
        "docker build -f Dockerfile.devbench -t distill-devbench:local .",
        "echo ''",
        "echo 'Pinned tool versions in this devbench image:'",
        "docker run --rm distill-devbench:local cat /etc/devbench/versions.txt"
      ],
      "mvp-container": [
        "# Wave 0 — run mvp-local inside the pinned devbench container.",
        "# Produces reproducible benchmark numbers traceable to the devbench digest.",
        "docker build -f Dockerfile.devbench -t distill-devbench:local .",
        "docker run --rm -it \\",
        "  -v \"$PWD\":/workspace \\",
        "  -v /var/run/docker.sock:/var/run/docker.sock \\",
        "  -w /workspace \\",
        "  --network host \\",
        "  distill-devbench:local \\",
        "  ./scripts/mvp-local.sh"
      ],
      "cache-up": [
        "# Wave 0.11 — start the opt-in OCI pull-through caches (Docker Hub + Red Hat).",
        "# Configure Docker daemon.json with:",
        "#   \"registry-mirrors\": [\"http://localhost:5556\"]",
        "cd local/registry && docker compose --profile cache up -d",
        "echo ''",
        "echo 'Caches started:'",
        "echo '  localhost:5556 → Docker Hub'",
        "echo '  localhost:5557 → registry.access.redhat.com'"
      ],
      "serve": [
        "# Wave 0 — serve the local landing page (audit + benchmark) on :8088.",
        "# Port 8080 is commonly taken on macOS by Docker Desktop; 8088 is reliably free.",
        "PORT=${PORT:-8088}",
        "cd site/local && echo \"serving http://localhost:${PORT}\" && python3 -m http.server \"${PORT}\""
      ],
      "scheduler-once": [
        "# Wave 0.6 — run one scheduling pass (check upstream, rebuild if changed).",
        "./scripts/rebuild-scheduler.sh once \"$@\""
      ],
      "scheduler-watch": [
        "# Wave 0.6 — run the scheduler continuously (default 15-minute interval).",
        "./scripts/rebuild-scheduler.sh watch \"$@\""
      ],
      "quality-gate": [
        "# Usage: devbox run quality-gate <image:tag> <quality-file> [--sbom <sbom>] [--key <cosign.pub>]",
        "# Runs all in-line quality-gate checks against a published image.",
        "./test/quality-gate/run-all.sh \"$@\""
      ],
      "bench": [
        "# Wave 0 benchmark: distill base-ubi9 vs. upstream UBI9 variants.",
        "./test/bench/compare.sh \\",
        "  --distill \"${DISTILL_IMAGE:-localhost:5555/base-ubi9:latest}\" \\",
        "  --vs docker.io/redhat/ubi9:latest \\",
        "  --vs registry.access.redhat.com/ubi9-minimal:latest \\",
        "  --vs registry.access.redhat.com/ubi9-micro:latest \\",
        "  --out test/bench/report"
      ],
      "evidence": [
        "# Usage: devbox run evidence <image:tag> <spec-file> <output-dir>",
        "# Generate the audit evidence bundle (SBOM + scans + provenance + compliance map).",
        "./test/audit/generate-evidence.sh \"$@\""
      ],
      "reproducibility": [
        "# Usage: devbox run reproducibility <spec-file> [runs]",
        "# Build the image N times and verify digests match. Default runs=2.",
        "./test/quality-gate/reproducibility.sh \"$@\""
      ]
    }
  }
}
